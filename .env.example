# Copy to .env — loaded by API (apps/api/src/load-env.ts)



# Must match — use = not : . URL-encode special chars in DATABASE_URL only (@ → %40, etc.)
POSTGRES_PASSWORD=dcc
DATABASE_URL=postgresql://dcc:dcc@localhost:5432/dcc



JWT_SECRET=generate-a-long-random-string

# API listen port on the host — nginx proxies here (rebuild nginx after changing: docker compose build nginx)
PORT=3003

CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Public URL (browser)
PUBLIC_URL=http://localhost:8080

# Docker nginx — local dev uses HTTP on 8080 (no TLS)
NGINX_TLS=false
NGINX_HTTP_PORT=8080



SESSION_COOKIE_NAME=dcc_session



# Transactional email (Resend) — https://resend.com/api-keys

# Verify hat3d.com (or subdomain) in Resend and add DNS records in GoDaddy first.

# MAIL_FROM must use an address on a verified domain (e.g. noreply@hat3d.com).

RESEND_API_KEY=

MAIL_FROM=noreply@hat3d.com



# Dev-only: two fixed logins (dev-dm@localhost / dev-player@localhost). Off in production unless true.

# ENABLE_DEV_LOGIN=true

# NODE_ENV=production



# Vite (host processes; nginx proxies here)

VITE_PORT=5173

VITE_HMR_CLIENT_PORT=8080

# Production TLS — see .env.production.example (NGINX_TLS=true, ports 80/443, LETSENCRYPT_DIR)



# --- Production (hat3d.com) — see docs/DEPLOYMENT.md and .env.production.example ---

# NODE_ENV=production

# PUBLIC_URL=https://hat3d.com

# CORS_ORIGIN=https://hat3d.com

