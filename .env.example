# Shared secrets — copy to .env (never commit).
# Profile settings live in .env.development / .env.production (see *.example files).

# Must match — use = not : . URL-encode special chars in DATABASE_URL only (@ → %40, etc.)
POSTGRES_PASSWORD=dcc
DATABASE_URL=postgresql://dcc:dcc@localhost:5432/dcc

JWT_SECRET=generate-a-long-random-string

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
MAIL_FROM=noreply@hat3d.com

# Optional local overrides (gitignored): .env.development.local / .env.production.local
