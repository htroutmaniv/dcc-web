# Development profile — copy to .env.development
# Loaded with .env when you run bun server, bun bundler, bun run stack, etc.

NODE_ENV=development

PUBLIC_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Docker nginx — HTTP on host 8080 (no TLS)
NGINX_TLS=false
NGINX_HTTP_PORT=8080

# API on host; nginx proxies here
PORT=3003

SESSION_COOKIE_NAME=dcc_session

# Vite dev server (host); nginx proxies here
VITE_PORT=5173
VITE_HMR_CLIENT_PORT=8080
VITE_HMR_PROTOCOL=ws
