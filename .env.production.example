# Production profile — copy to .env.production
# Loaded with .env when you run bun run prod / bun run stack:prod

NODE_ENV=production

PUBLIC_URL=https://hat3d.com
CORS_ORIGIN=https://hat3d.com

# Docker nginx — TLS on host 80/443
NGINX_TLS=true
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_SERVER_NAME=hat3d.com www.hat3d.com
LETSENCRYPT_DIR=D:/Work/docker/letsencrypt

PORT=3003
HOST=0.0.0.0

SESSION_COOKIE_NAME=dcc_session

# Production serves built assets via vite preview
VITE_PORT=5173

# Do not enable on a public server
# ENABLE_DEV_LOGIN=false
