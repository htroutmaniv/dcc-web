generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GameStatus {
  active
  archived
}

enum GamePlayerRole {
  player
  co_dm
}

enum CharacterStatus {
  alive
  dead
  archived
}

enum CharacterSource {
  manual
  random
  purple_sorcerer
  import
}

enum ItemCategory {
  weapon
  armor
  treasure
  misc
  disposable
}

enum TokenKind {
  pc
  npc
  object
  monster
}

enum TokenZone {
  map
  holding
}

enum MovementRequestStatus {
  pending
  accepted
  rejected
}

enum OccupationRace {
  elf
  dwarf
  halfling
}

enum CharacterNameKind {
  first
  last
}

enum AuthTokenType {
  verify_email
  password_reset
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String?   @unique
  displayName     String    @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  passwordHash    String?   @map("password_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  dmGames       Game[]         @relation("DmGames")
  gamePlayers   GamePlayer[]
  characters    Character[]
  diceRolls     DiceRoll[]
  movementReqs  MovementRequest[] @relation("MovementRequester")
  authTokens    AuthToken[]

  @@map("users")
}

model AuthToken {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  type      AuthTokenType
  tokenHash String        @map("token_hash")
  expiresAt DateTime      @map("expires_at")
  createdAt DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@map("auth_tokens")
}

enum PlayerTokenMovement {
  free
  approval

  @@map("player_token_movement")
}

model Game {
  id                      String              @id @default(uuid()) @db.Uuid
  dmUserId                String              @map("dm_user_id") @db.Uuid
  title                   String
  inviteCode              String              @unique @map("invite_code")
  status                  GameStatus          @default(active)
  activeMapId             String?             @map("active_map_id") @db.Uuid
  monstersVisibleOnMap    Boolean             @default(false) @map("monsters_visible_on_map")
  sharedMonsterInitiative Boolean             @default(false) @map("shared_monster_initiative")
  hideMonsterAcInRollLog  Boolean             @default(false) @map("hide_monster_ac_in_roll_log")
  gridFtPerCell           Decimal             @default(5) @map("grid_ft_per_cell") @db.Decimal(6, 2)
  playerTokenMovement     PlayerTokenMovement @default(free) @map("player_token_movement")
  createdAt               DateTime            @default(now()) @map("created_at")

  dm               User              @relation("DmGames", fields: [dmUserId], references: [id])
  players          GamePlayer[]
  characters       Character[]
  monsters         GameMonster[]
  maps             GameMap[]
  diceRolls        DiceRoll[]
  movementRequests MovementRequest[]
  activeMap        GameMap?          @relation("ActiveGameMap", fields: [activeMapId], references: [id], onDelete: SetNull)
  initiative       GameInitiative?

  @@index([dmUserId, status])
  @@map("games")
}

model GameInitiative {
  gameId    String   @id @map("game_id") @db.Uuid
  state     Json
  version   Int      @default(1)
  updatedAt DateTime @updatedAt @map("updated_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_initiative")
}

model GamePlayer {
  gameId   String         @map("game_id") @db.Uuid
  userId   String         @map("user_id") @db.Uuid
  role     GamePlayerRole @default(player)
  joinedAt DateTime       @default(now()) @map("joined_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gameId, userId])
  @@index([userId])
  @@map("game_players")
}

model Character {
  id            String          @id @default(uuid()) @db.Uuid
  gameId        String          @map("game_id") @db.Uuid
  ownerUserId   String          @map("owner_user_id") @db.Uuid
  name          String
  level         Int             @default(0)
  className     String          @default("") @map("class_name")
  alignment     String          @default("")
  status        CharacterStatus @default(alive)
  diedAt        DateTime?       @map("died_at")
  archivedAt    DateTime?       @map("archived_at")
  portraitUrl   String?         @map("portrait_url")
  stats         Json
  combat        Json
  notes         String          @default("")
  source        CharacterSource @default(manual)
  sourcePayload Json?           @map("source_payload")
  version       Int             @default(1)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  game     Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  owner    User            @relation(fields: [ownerUserId], references: [id])
  items    CharacterItem[]
  tokens   MapToken[]
  diceRolls DiceRoll[]

  @@index([gameId, ownerUserId])
  @@index([gameId, status])
  @@map("characters")
}

model LootPool {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String   @default("")
  entries     Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")

  monsters MonsterCatalog[]

  @@map("loot_pools")
}

model MonsterCatalog {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String   @default("")
  baseLevel   Int      @default(1) @map("base_level")
  hitDice     String   @default("1d8") @map("hit_dice")
  ac          Int      @default(12)
  attackBonus Int      @default(0) @map("attack_bonus")
  damage      String   @default("1d6")
  initMod     Int      @default(0) @map("init_mod")
  speed       Int      @default(30)
  hpAvg       Int?     @map("hp_avg")
  tags        String[] @default([])
  sheet       Json     @default("{}")
  stats       Json     @default("{}")
  combat      Json     @default("{}")
  lootPoolId  String?  @map("loot_pool_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  lootPool  LootPool?     @relation(fields: [lootPoolId], references: [id], onDelete: SetNull)
  instances GameMonster[]

  @@map("monster_catalog")
}

model GameMonster {
  id          String   @id @default(uuid()) @db.Uuid
  gameId      String   @map("game_id") @db.Uuid
  catalogId   String?  @map("catalog_id") @db.Uuid
  name        String
  scaleLevel  Int      @default(1) @map("scale_level")
  hitDice     String   @default("1d8") @map("hit_dice")
  ac          Int      @default(12)
  attackBonus Int      @default(0) @map("attack_bonus")
  damage      String   @default("1d6")
  initMod     Int      @default(0) @map("init_mod")
  speed       Int      @default(30)
  hpMax       Int      @map("hp_max")
  hpCurrent   Int      @map("hp_current")
  notes       String   @default("")
  sheet       Json     @default("{}")
  stats       Json     @default("{}")
  combat      Json     @default("{}")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  game    Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  catalog MonsterCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  items     MonsterItem[]
  mapTokens MapToken[]

  @@index([gameId, sortOrder])
  @@map("game_monsters")
}

model MonsterItem {
  id         String       @id @default(uuid()) @db.Uuid
  monsterId  String       @map("monster_id") @db.Uuid
  category   ItemCategory
  name       String
  quantity   Int          @default(1)
  properties Json         @default("{}")
  sortOrder  Int          @default(0) @map("sort_order")
  notes      String       @default("")

  monster GameMonster @relation(fields: [monsterId], references: [id], onDelete: Cascade)

  @@index([monsterId, sortOrder])
  @@map("monster_items")
}

model Occupation {
  id                String          @id @default(uuid()) @db.Uuid
  rollLow           Int             @map("roll_low")
  rollHigh          Int             @map("roll_high")
  name              String          @unique
  race              OccupationRace?
  trainedWeapon     String          @map("trained_weapon")
  weaponDamage      String          @map("weapon_damage")
  weaponAttackBonus Int             @default(0) @map("weapon_attack_bonus")
  tradeGoods        String          @map("trade_goods")
  sortOrder         Int             @default(0) @map("sort_order")

  @@index([rollLow, rollHigh])
  @@map("occupations")
}

model CharacterName {
  id        String            @id @default(uuid()) @db.Uuid
  kind      CharacterNameKind
  name      String
  sortOrder Int               @default(0) @map("sort_order")

  @@unique([kind, name])
  @@index([kind])
  @@map("character_names")
}

model ItemCatalog {
  id          String       @id @default(uuid()) @db.Uuid
  category    ItemCategory
  name        String
  description String       @default("")
  properties  Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@unique([category, name])
  @@index([category])
  @@map("item_catalog")
}

model CharacterItem {
  id          String       @id @default(uuid()) @db.Uuid
  characterId String       @map("character_id") @db.Uuid
  category    ItemCategory
  name        String
  quantity    Int          @default(1)
  weight      Decimal?     @db.Decimal(10, 2)
  properties  Json         @default("{}")
  sortOrder   Int          @default(0) @map("sort_order")
  notes       String       @default("")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, category])
  @@map("character_items")
}

model GameMap {
  id             String   @id @default(uuid()) @db.Uuid
  gameId         String   @map("game_id") @db.Uuid
  name           String   @default("Main map")
  sortOrder      Int      @default(0) @map("sort_order")
  visible        Boolean  @default(true)
  gridPreset     String   @default("tactical") @map("grid_preset")
  imageUrl       String?  @map("image_url")
  widthPx        Int      @default(0) @map("width_px")
  heightPx       Int      @default(0) @map("height_px")
  imageScale     Float    @default(1) @map("image_scale")
  gridCellPx     Int      @default(50) @map("grid_cell_px")
  gridFtPerCell  Decimal  @default(5) @map("grid_ft_per_cell") @db.Decimal(6, 2)
  dmDrawings     Json     @default("[]") @map("dm_drawings")
  updatedAt      DateTime @updatedAt @map("updated_at")

  game           Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  activeForGames Game[]     @relation("ActiveGameMap")
  tokens         MapToken[]

  @@index([gameId, sortOrder])
  @@map("game_maps")
}

model MapToken {
  id           String    @id @default(uuid()) @db.Uuid
  mapId        String    @map("map_id") @db.Uuid
  kind         TokenKind
  characterId  String?   @map("character_id") @db.Uuid
  monsterId    String?   @map("monster_id") @db.Uuid
  label        String
  x            Float
  y            Float
  zone         TokenZone @default(holding)
  color        String    @default("#c9a227")
  iconUrl      String?   @map("icon_url")
  hpMax        Int?      @map("hp_max")
  hpCurrent    Int?      @map("hp_current")
  sortOrder    Int       @default(0) @map("sort_order")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  map       GameMap      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  character Character?   @relation(fields: [characterId], references: [id], onDelete: SetNull)
  monster   GameMonster? @relation(fields: [monsterId], references: [id], onDelete: SetNull)

  @@index([mapId, zone])
  @@map("map_tokens")
}

model DiceRoll {
  id          String   @id @default(uuid()) @db.Uuid
  gameId      String   @map("game_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  characterId String?  @map("character_id") @db.Uuid
  notation    String
  rolls       Json
  modifier    Int
  total       Int
  reason      String?
  rollKind    String   @default("unspecified") @map("roll_kind")
  createdAt   DateTime @default(now()) @map("created_at")

  game      Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])
  character Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)

  @@index([gameId, createdAt])
  @@map("dice_rolls")
}

model MovementRequest {
  id             String                @id @default(uuid()) @db.Uuid
  gameId         String                @map("game_id") @db.Uuid
  tokenId        String                @map("token_id") @db.Uuid
  requesterId    String                @map("requester_id") @db.Uuid
  targetX        Float                 @map("target_x")
  targetY        Float                 @map("target_y")
  targetZone     TokenZone             @map("target_zone")
  status         MovementRequestStatus @default(pending)
  createdAt      DateTime              @default(now()) @map("created_at")
  resolvedAt     DateTime?             @map("resolved_at")

  game      Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  requester User @relation("MovementRequester", fields: [requesterId], references: [id])

  @@index([gameId, status])
  @@map("movement_requests")
}
