{
  "name": "@dcc-web/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "server": "bun --watch src/index.ts ../../packages/shared/dist",
    "dev": "bun run server",
    "start": "bun dist/index.js",
    "db:generate": "bun ../../scripts/prisma-env.ts generate",
    "db:migrate": "bun ../../scripts/prisma-env.ts migrate deploy",
    "db:migrate:dev": "bun ../../scripts/prisma-env.ts migrate dev",
    "db:push": "bun ../../scripts/prisma-env.ts db push",
    "db:studio": "bun ../../scripts/prisma-env.ts studio",
    "db:seed": "bun ../../scripts/prisma-env.ts db seed"
  },
  "dependencies": {
    "@dcc-web/shared": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "bun prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/node": "^22.13.4",
    "prisma": "^6.3.1",
    "typescript": "^5.7.3"
  }
}
